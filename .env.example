PORT=3000

# Postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=payment_system

# Redis (used for BullMQ queue + distributed locks)
REDIS_HOST=localhost
REDIS_PORT=6379

# Payment processing tunables
PAYMENT_MAX_ATTEMPTS=4
PAYMENT_BACKOFF_INITIAL_MS=2000
PAYMENT_LOCK_TTL_SECONDS=60
GATEWAY_TIMEOUT_MS=5000

# Webhook security
# Generate one with: openssl rand -hex 32
WEBHOOK_SIGNING_SECRET=change-me-to-a-long-random-secret

# Circuit breaker for the fake gateway
CB_FAILURE_THRESHOLD=5
CB_OPEN_DURATION_MS=20000

# Rate limit (requests per minute per IP)
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=60
